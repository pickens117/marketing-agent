{
  "name": "marketing-agent",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "A marketing-focused Claude agent built with the Claude Agent SDK.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bootstrap:company": "tsx src/index.ts --bootstrap-company",
    "generate:plugin": "tsx scripts/generate-plugin-assets.ts",
    "eval": "tsx scripts/evaluate.ts",
    "test": "tsx --test test/**/*.test.ts",
    "test:source": "tsx --test test/**/*.test.ts",
    "chat": "tsx src/index.ts --interactive",
    "agent": "tsx src/index.ts",
    "verify": "npm run build && npm run test && npm run generate:plugin && claude plugin validate . && claude plugin validate ./plugins/marketing-ai-enablement-plugin"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.79",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18"
  }
}
